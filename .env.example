# Copy to .env.local and fill in as needed. All values are optional — the app
# parses GenPept records with a built-in TypeScript parser, so no Python is
# required to run it.

# NCBI E-utilities API key. Without a key E-utilities is capped at 3 req/sec;
# with a key, 10 req/sec. Recommended. Get one from your NCBI account settings:
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# Optional: identify your tool to NCBI (recommended by their usage guidelines).
NCBI_TOOL=geobacillus-ncbi-explorer
NCBI_EMAIL=

# --- Optional: use BioPython instead of the built-in TS parser ---------------
# Set USE_PYTHON_PARSER=1 to parse via api/parse_genpept.py (needs biopython).
# Point PYTHON_BIN at an interpreter that has biopython installed, e.g. a venv:
#   USE_PYTHON_PARSER=1
#   PYTHON_BIN=./.venv/bin/python
# If the Python parser fails for any reason, the app automatically falls back to
# the built-in TS parser, so results are never blank.
# USE_PYTHON_PARSER=
# PYTHON_BIN=python3
